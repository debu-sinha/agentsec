{
  "version": "2026.2.15",
  "gateway": {
    "bind": "loopback",
    "controlUi": {
      "allowInsecureAuth": false
    }
  },
  "dmPolicy": "paired",
  "groupPolicy": "allowlist",
  "tools": {
    "profile": "messaging"
  },
  "sandbox": {
    "mode": "non-main"
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "discovery": {
    "mdns": {
      "mode": "minimal"
    }
  },
  "dangerouslyDisableDeviceAuth": false,
  "dangerouslyDisableAuth": false
}